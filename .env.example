# Core settings
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/caltrain_alerts
# Option A: provide a full URL
# REDIS_URL=redis://localhost:6379/0
# Railway sometimes provides `REDIS_PUBLIC_URL` too (useful for managed Redis).
# REDIS_PUBLIC_URL=replace_me

# Option B: provide pieces (useful for managed Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Railway aliases (if those are what you see in the UI):
# REDISHOST=localhost
# REDISPORT=6379
# REDISUSER=
# REDISPASSWORD=

# 511 API
SOURCES_511_ENABLED=true
API_511_KEY=replace_me

# Reddit API (praw OAuth)
SOURCES_REDDIT_ENABLED=true
REDDIT_CLIENT_ID=replace_me
REDDIT_CLIENT_SECRET=replace_me
REDDIT_USERNAME=replace_me
REDDIT_PASSWORD=replace_me
REDDIT_USER_AGENT=caltrain-alerts-mvp/0.1 by-your-reddit-handle
REDDIT_SUBREDDITS=caltrain,bayarea

# Anthropic / Claude
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Twilio
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=replace_me
SEND_MIN_SEVERITY=CRITICAL
INCIDENT_DEDUP_WINDOW_MINUTES=10
SUBSCRIBER_SEND_COOLDOWN_MINUTES=60
SMS_TEMPLATE=Caltrain alert ({{severity}}): {{title}}\n{{message}}

# Operational / scheduling
POLL_511_INTERVAL_SECONDS=60
POLL_REDDIT_INTERVAL_SECONDS=120

# Admin (optional)
# If set, require X-Admin-Token header for admin endpoints.
ADMIN_API_KEY=replace_me

