ENVIRONMENT=development

# Docker Postgres (we remapped host port to 5433 to avoid conflict with your local Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/caltrain_alerts

# Redis (from docker compose)
REDIS_URL=redis://127.0.0.1:6379/0

# Disable external sources for local smoke tests
SOURCES_511_ENABLED=false
SOURCES_REDDIT_ENABLED=false

# No external notifications/classification in local smoke mode
SEND_MIN_SEVERITY=CRITICAL

